# Mock mode (default) — set to false when you have real credentials
DATABRICKS_MOCK=true

# Live mode credentials (required when DATABRICKS_MOCK=false)
DATABRICKS_HOST=https://adb-XXXXXXXXXXXXXXXX.X.azuredatabricks.net
DATABRICKS_TOKEN=dapi...

# Optional defaults
DATABRICKS_WAREHOUSE_ID=your_warehouse_id
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=default
